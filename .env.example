SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your_email@example.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=your_email@example.com
SMTP_USE_TLS=true
SMTP_USE_SSL=false
ALERT_EMAIL=security_team@example.com
ASSET_SENTINEL_DATABASE_URL=postgresql://username:password@host/database
ASSET_SENTINEL_JWT_SECRET=your_secret_here
ASSET_SENTINEL_BOOTSTRAP_ADMIN_USERNAME=admin_username
ASSET_SENTINEL_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
ASSET_SENTINEL_BOOTSTRAP_ADMIN_PASSWORD=your_admin_password
